{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Experience",
  "description": "Work history for the portfolio. Add/remove/reorder items here — the Experience section auto-renders them. No code changes needed.",
  "type": "object",
  "required": ["items"],
  "properties": {
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "company", "role", "period", "location", "accent", "highlights"],
        "properties": {
          "id": { "type": "string", "description": "Unique slug (used as React key)" },
          "company": { "type": "string" },
          "role": { "type": "string" },
          "period": { "type": "string", "description": "e.g. '12/2025 – Present'" },
          "location": { "type": "string" },
          "current": { "type": "boolean", "description": "True for the current/most-recent role — shows a pulse on the timeline dot" },
          "accent": { "type": "string", "enum": ["amber", "orange", "magenta", "green"] },
          "highlights": { "type": "array", "items": { "type": "string" }, "description": "Bullet-point achievements" }
        }
      }
    }
  }
}
