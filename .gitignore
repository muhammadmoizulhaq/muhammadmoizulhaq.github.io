# --- Cleanup for GitHub push (sandbox-only artifacts) ---
# Local SQLite database (binary, regenerated by prisma db push)
/db/*.db
/db/*.db-journal
# QA / debug screenshots and VLM dumps (not part of the site)
/download/
# Tool-result debug dumps from agent sessions
/tool-results/
# Sandbox-internal helper scripts (not needed on GitHub)
/.zscripts/
# Local environment file (keep secrets out of git even if just a path)
.env
